{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "FX AI Trader",
    "version":  "1.0.0",
    "identifier":  "com.fx-ai-trader.desktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build",
                  "devUrl":  "http://localhost:5173",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "FX AI Trader",
                                    "width":  1280,
                                    "height":  820,
                                    "minWidth":  900,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "decorations":  true,
                                    "transparent":  false
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027 \u0027unsafe-inline\u0027 \u0027unsafe-eval\u0027; connect-src \u0027self\u0027 http://127.0.0.1:8742; script-src \u0027self\u0027 \u0027unsafe-inline\u0027 \u0027unsafe-eval\u0027"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/icon.ico"
                            ]
               },
    "plugins":  {
                    "shell":  {
                                  "open":  true
                              },
                    "store":  null,
                    "notification":  null
                }
}
